---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  content: CollectionEntry<'article' | 'pages'>;
}

const { content } = Astro.props;
const { Content } = await render(content);
---

<article class="markdown-body">
  <Content />
</article>

<script>
  import mediumZoom from 'medium-zoom';

  const markdownImages = '.markdown-body img:not(.og-card-image)';
  mediumZoom(markdownImages, {
    margin: 24,
    background: 'rgba(0, 0, 0, 0.85)',
  });
</script>

<style>
  :global(.markdown-body img:not(.og-card-image)) {
    display: block;
    width: auto;
    max-width: min(100%, 90vw, 960px);
    max-height: 480px;
    height: auto;
    margin: 1.5rem auto;
    cursor: zoom-in;
    object-fit: contain;
  }
</style>
