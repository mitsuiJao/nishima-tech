---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarkdownContent from '../../components/MarkdownContent.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('article');
  return articles.map((article) => ({
    params: { slug: article.id.replace(/\/index$/, '') || article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const title = (article.data as { title?: string }).title ?? article.id;
---

<BaseLayout title={title}>
  <div class="post-article">
    <h1>{article.data.title}</h1>
    <p>{article.data.date}</p>
    {article.data.tags && article.data.tags.length > 0 && (
      <ul class="tag-list">
        {article.data.tags.map((tag) => (
          <li>
            <a href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>
          </li>
        ))}
      </ul>
    )}
  </div>
  <MarkdownContent content={article} />
</BaseLayout>

<style>
  /* 1a1a1a */
.post-article {
    /* 背景や枠線を消してシンプルに */
    background-color: transparent;
    padding: 0;
    border: none;
    box-shadow: none;

    /* 下線と余白で「ここから本文」という境界を作る */
    margin-bottom: 3rem;   /* 本文との間の距離 */
    padding-bottom: 3rem; /* タイトルから下線までの距離 */
    border-bottom: 1px solid #333; /* 控えめな区切り線 */
  }

  .post-article h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: #fff;
  }

  .post-article p {
    color: #888;
    font-size: 0.9rem;
    margin: 0;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
  }

  .tag-list li {
    margin: 0;
  }

  .tag-list a {
    display: inline-block;
    padding: 0.2rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-muted);
    font-size: 0.8rem;
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }

  .tag-list a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
