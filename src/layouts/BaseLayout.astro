---
import Footer from "../components/Footer.astro";
import './index.css';

interface Props {
  title?: string;
  description?: string;
  siteTitle?: string;
}

const { title = "", description = "", siteTitle: siteTitleProp } = Astro.props;
const config = await import("../config.json").then((m) => m.default);
const siteTitle = siteTitleProp ?? config.site?.title ?? "homepage";
const siteDesc = config.site?.description ?? "";
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const metaDesc = description || siteDesc;
---

<!doctype html>
<html lang="ja" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={metaDesc} />
    <title>{pageTitle}</title>
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2173470513894649"
      crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
      crossorigin="anonymous"
    />
    <!-- <style is:global>
    </style> -->
  </head>
  <body>
    <header
      style="border-bottom: 1px solid var(--color-border); margin-bottom: 2rem;"
    >
      <nav
        style="max-width: 56rem; margin: 0 auto; padding: 1rem 1.5rem; display: flex; align-items: center; gap: 1.5rem;"
      >
        <slot name="headerTitle">
          <a href="/" style="font-weight: 800;">nishima-techメモ</a>
        </slot>
        <!-- {
          config.routes
            ?.filter(
              (r: { path: string }) => r.path !== "/" && !r.path.includes("["),
            )
            ?.map((r: { path: string; title: string }) => (
              <a href={r.path}>{r.title}</a>
            ))
        } -->
        <a href="/about">About</a>
        <a href="/articles">Article</a>
        <a href="/tags">Tags</a>

        <a
          href="https://github.com/mitsuijao"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          style="margin-left: auto; display: flex; align-items: center; color: var(--color-text);"
        >
          <svg height="24" viewBox="0 0 16 16" width="24" fill="currentColor">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
        </a>
      </nav>
    </header>
    <main
      style="flex: 1; width: 100%; max-width: 56rem; margin: 0 auto; padding: 0 1.5rem 4rem;"
    >
      <slot />
    </main>
    <Footer />
  </body>
</html>
